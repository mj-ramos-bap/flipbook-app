# =============================================================================
# Cloud Run Environment Variables — copy to Cloud Run secrets/env vars
# Sensitive values go in Secret Manager; non-sensitive go as plain env vars.
# =============================================================================

# --- Database (Cloud SQL PostgreSQL) ---
# Unix socket format for Cloud Run + Cloud SQL (recommended)
DATABASE_URL=postgresql://flipbook:YOUR_PASSWORD@/flipbook?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# TCP format (if using direct private IP instead of socket)
# DATABASE_URL=postgresql://flipbook:YOUR_PASSWORD@PRIVATE_IP:5432/flipbook

# --- Auth ---
NEXTAUTH_URL=https://YOUR_CLOUD_RUN_URL_OR_CUSTOM_DOMAIN
NEXTAUTH_SECRET=generate-with--openssl-rand-base64-32

# --- Google Cloud Storage (via S3-compatible HMAC API) ---
# Create HMAC keys at: GCP Console > Cloud Storage > Settings > Interoperability
GCS_BUCKET_NAME=YOUR_BUCKET_NAME
GCS_HMAC_ACCESS_ID=GOOG1E...
GCS_HMAC_SECRET=YOUR_HMAC_SECRET

# --- Optional: Google OAuth (if using Google SSO) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
